<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="org.kaorun.nouto.ui.fragments.MainFragment"
        android:label="fragment_main"
        tools:layout="@layout/fragment_main" >
        <action
            android:id="@+id/action_mainFragment_to_noteFragment"
            app:destination="@id/noteFragment" />
        <action
            android:id="@+id/action_mainFragment_to_settingsMainFragment"
            app:destination="@id/settingsMainFragment" />
        <action
            android:id="@+id/action_mainFragment_to_recentlyDeletedFragment"
            app:destination="@id/recentlyDeletedFragment" />
    </fragment>

    <fragment
        android:id="@+id/noteFragment"
        android:name="org.kaorun.nouto.ui.fragments.NoteFragment"
        android:label="fragment_note"
        tools:layout="@layout/fragment_note">
        <argument
            android:name="note_id"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>
    <fragment
        android:id="@+id/settingsMainFragment"
        android:name="org.kaorun.nouto.ui.fragments.settings.SettingsMainFragment"
        android:label="SettingsFragment"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settingsMainFragment_to_settingsAppearanceFragment"
            app:destination="@id/settingsAppearanceFragment" />
        <action
            android:id="@+id/action_settingsMainFragment_to_settingsAboutFragment"
            app:destination="@id/settingsAboutFragment" />
    </fragment>
    <fragment
        android:id="@+id/settingsAppearanceFragment"
        android:name="org.kaorun.nouto.ui.fragments.settings.SettingsAppearanceFragment"
        android:label="SettingsAppearanceFragment"
        tools:layout="@layout/fragment_settings" />
    <fragment
        android:id="@+id/recentlyDeletedFragment"
        android:name="org.kaorun.nouto.ui.fragments.RecentlyDeletedFragment"
        android:label="RecentlyDeletedFragment"
        tools:layout="@layout/fragment_recently_deleted">
        <action
            android:id="@+id/action_recentlyDeletedFragment_to_noteFragment"
            app:destination="@id/noteFragment" />
    </fragment>
    <fragment
        android:id="@+id/settingsAboutFragment"
        android:name="org.kaorun.nouto.ui.fragments.settings.SettingsAboutFragment"
        android:label="SettingsAboutFragment"
        tools:layout="@layout/fragment_settings" />

</navigation>