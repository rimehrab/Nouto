<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Widget.Custom.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
    </style>

    <style name="Widget.Material3.ListItemCardView.Segmented" parent="" tools:override="true">
        <item name="cardBackgroundColor">@color/segmented_list_item_background</item>
    </style>


    <style name="ShapeAppearance.Material3.ListItem.First" parent="" tools:override="true">
        <item name="cornerFamily">?attr/shapeCornerFamily</item>
        <item name="cornerSizeTopLeft">?attr/shapeCornerSizeLargeIncreased</item>
        <item name="cornerSizeTopRight">?attr/shapeCornerSizeLargeIncreased</item>
        <item name="cornerSizeBottomLeft">?attr/shapeCornerSizeExtraSmall</item>
        <item name="cornerSizeBottomRight">?attr/shapeCornerSizeExtraSmall</item>
    </style>

    <style name="ShapeAppearance.Material3.ListItem.Middle" parent="" tools:override="true">
        <item name="cornerFamily">?attr/shapeCornerFamily</item>
        <item name="cornerSize">?attr/shapeCornerSizeExtraSmall</item>
    </style>

    <style name="ShapeAppearance.Material3.ListItem.Last" parent="" tools:override="true">
        <item name="cornerFamily">?attr/shapeCornerFamily</item>
        <item name="cornerSizeTopLeft">?attr/shapeCornerSizeExtraSmall</item>
        <item name="cornerSizeTopRight">?attr/shapeCornerSizeExtraSmall</item>
        <item name="cornerSizeBottomLeft">?attr/shapeCornerSizeLargeIncreased</item>
        <item name="cornerSizeBottomRight">?attr/shapeCornerSizeLargeIncreased</item>
    </style>

    <style name="ShapeAppearance.Material3.ListItem.Single" parent="" tools:override="true">
        <item name="cornerFamily">?attr/shapeCornerFamily</item>
        <item name="cornerSize">?attr/shapeCornerSizeLargeIncreased</item>
    </style>

    <style name="ShapeAppearance.Material3.ListItem.Checked" parent="" tools:override="true">
        <item name="cornerFamily">?attr/shapeCornerFamily</item>
        <item name="cornerSize">?attr/shapeCornerSizeLargeIncreased</item>
    </style>

    <style name="PreferenceThemeOverlay.v14.Material" tools:override="true">
        <item name="preferenceStyle">@style/SegmentedListPreferenceItem</item>
        <item name="dialogPreferenceStyle">@style/SegmentedListPreferenceItem</item>
        <item name="switchPreferenceCompatStyle">@style/SegmentedListSwitchPreferenceItem</item>
        <item name="preferenceCategoryStyle">@style/MaterialPreferenceCategory</item>
    </style>

    <style name="MaterialPreferenceCategory" parent="@style/Preference.Category">
        <item name="android:layout">@layout/item_preference_category</item>
    </style>

    <style name="SegmentedListPreferenceItem" parent="Preference">
        <item name="android:layout">@layout/item_preference</item>
    </style>

    <style name="SegmentedListSwitchPreferenceItem" parent="Preference.SwitchPreferenceCompat">
        <item name="android:layout">@layout/item_preference</item>
    </style>


    <style name="Widget.Material3Expressive.FloatingActionButton.Large.Error" parent="Widget.Material3Expressive.FloatingActionButton.Large">
        <item name="materialThemeOverlay">@style/ThemeOverlay.Material3Expressive.FloatingActionButton.Error</item>
    </style>

    <style name="ButtonDialogNegative" parent="Widget.Material3Expressive.Button.OutlinedButton">
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:textColor">?colorError</item>
    </style>
</resources>